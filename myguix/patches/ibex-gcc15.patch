diff --git a/ibex.pc.in b/ibex.pc.in
--- a/ibex.pc.in
+++ b/ibex.pc.in
@@ -6,5 +6,5 @@ Description: A C++ library for interval-based algorithm design
 Version: @VERSION@
 Requires: clp
-Cflags: -I${includedir} -I${includedir}/ibex -I${includedir}/ibex/3rd -frounding-math -ffloat-store -msse3
+Cflags: -I${includedir} -I${includedir}/ibex -I${includedir}/ibex/3rd -frounding-math -ffloat-store -msse3 -D_GLIBCXX_HAVE_FENV_H=1
 Libs: -L${libdir} -libex

